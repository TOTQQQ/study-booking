.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

.filter-bar {
  background: white;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  border-bottom: 1rpx solid #eee;
}

.filter-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.filter-item .label {
  color: #666;
  margin-right: 16rpx;
}

.filter-item .picker {
  color: #333;
  background: #f5f5f5;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}

.seat-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 30rpx;
  gap: 20rpx;
}

.seat-item {
  width: calc(25% - 20rpx);
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

/* 可约 - 蓝色 */
.seat-item.available {
  background: #e3f2fd;
  border: 2rpx solid #2196f3;
}

.seat-item.available .seat-code {
  color: #2196f3;
}

/* 已约 - 灰色 */
.seat-item.used {
  background: #f0f0f0;
  border: 2rpx solid #ccc;
}

.seat-item.used .seat-code {
  color: #999;
}

.seat-code {
  font-size: 28rpx;
  font-weight: 500;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* 弹窗样式 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.popup-content {
  width: 85%;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.popup-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.popup-header .title {
  font-size: 34rpx;
  font-weight: bold;
}

.popup-header .close {
  font-size: 48rpx;
  color: #999;
}

.popup-body {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
}

.info-row {
  display: flex;
  margin-bottom: 24rpx;
  font-size: 30rpx;
}

.info-row .label {
  width: 140rpx;
  color: #666;
}

.info-row .value {
  color: #333;
  font-weight: 500;
}

.time-select .label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.time-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.time-item {
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
}

.time-item.selected {
  background: #2196f3;
  color: white;
}

.time-item.disabled {
  background: #f0f0f0;
  color: #ccc;
  text-decoration: line-through;
}

.popup-footer {
  display: flex;
  border-top: 1rpx solid #eee;
}

.popup-footer button {
  flex: 1;
  margin: 0;
  border-radius: 0;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 32rpx;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-confirm {
  background: #2196f3;
  color: white;
}