.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

/* 头部样式 */
.header {
  position: relative;
  height: 280rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(135deg, #1677ff 0%, #69c0ff 100%);
  border-radius: 0 0 30rpx 30rpx;
}

.header-content {
  position: relative;
  padding: 60rpx 40rpx;
}

.app-name {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
}

.slogan {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

/* 统计卡片 - 2个卡片均分 */
.stats {
  display: flex;
  margin: -40rpx 30rpx 30rpx;
  gap: 20rpx;
}

.stat-card {
  flex: 1;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #1677ff;
  margin-bottom: 12rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 功能入口 */
.functions {
  margin: 0 30rpx;
  background: white;
  border-radius: 20rpx;
  padding: 20rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.func-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.func-item:last-child {
  border-bottom: none;
}

.func-icon {
  width: 80rpx;
  height: 80rpx;
  background: #f0f7ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.func-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.func-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 系统规则 */
.rules {
  margin: 30rpx;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.rules-header {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.rules-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rule-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}