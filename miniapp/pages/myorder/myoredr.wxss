.container {
  padding: 20rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  padding: 20rpx 10rpx;
}

.order-box {
  padding-bottom: 30rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 120rpx 40rpx;
  background: white;
  border-radius: 20rpx;
  margin-top: 50rpx;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 40rpx;
}

.btn-outline {
  background: white;
  color: #1677ff;
  border: 2rpx solid #1677ff;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  width: 60%;
  margin: 0 auto;
}

/* 预约卡片 */
.order-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.seat-badge {
  font-size: 32rpx;
  font-weight: bold;
  color: #1677ff;
}

.status-badge {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

.status-badge.status-pending {
  background: #FFF3E0;
  color: #FF9800;
}

.status-badge.status-checked {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-badge.status-other {
  background: #EEEEEE;
  color: #999;
}

.card-body {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  padding: 12rpx 0;
}

.info-label {
  width: 100rpx;
  font-size: 28rpx;
  color: #999;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 按钮区域 */
.card-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn {
  flex: 1;
  background: #fff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx;
}

.checkin-btn {
  flex: 1;
  background: #1677ff;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx;
}