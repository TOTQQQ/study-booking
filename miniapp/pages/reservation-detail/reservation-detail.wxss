@import "/app.wxss";

.container {
  padding: 30rpx;
  background-color: #f5f7fa;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 48rpx 30rpx;
  text-align: center;
  margin-bottom: 30rpx;
  color: white;
}

.status-card.status-1 {
  background: linear-gradient(135deg, #1677ff 0%, #69b1ff 100%);
}

.status-card.status-2 {
  background: linear-gradient(135deg, #52c41a 0%, #95de64 100%);
}

.status-card.status-3 {
  background: linear-gradient(135deg, #999 0%, #bbb 100%);
}

.status-card.status-4 {
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.status-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 通用卡片 */
.card {
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  padding-bottom: 24rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.title-icon {
  font-size: 36rpx;
}

.info-row {
  display: flex;
  padding: 16rpx 0;
}

.info-row .label {
  width: 160rpx;
  color: #999;
  font-size: 28rpx;
}

.info-row .value {
  flex: 1;
  color: #333;
  font-size: 28rpx;
}

.info-row .value.highlight {
  color: #1677ff;
  font-weight: 500;
  font-size: 32rpx;
}

.info-row .value.mono {
  font-family: monospace;
  font-size: 26rpx;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 24rpx;
  margin: 30rpx 0;
}

.btn-primary {
  flex: 1;
  background-color: #1677ff;
  color: white;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.btn-outline {
  flex: 1;
  background-color: white;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 500;
}

/* 提示卡片 */
.tips-card {
  background-color: #e8f5e9;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tips-card.warning {
  background-color: #fff3e0;
}

.tips-icon {
  font-size: 40rpx;
}

.tips-text {
  flex: 1;
  font-size: 26rpx;
  color: #4caf50;
}

.tips-card.warning .tips-text {
  color: #ff9800;
}

/* 规则卡片 */
.rules-card {
  background-color: #f0f7ff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 10rpx;
}

.rules-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1677ff;
  margin-bottom: 16rpx;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rules-list text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}