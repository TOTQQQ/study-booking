<view class="container">
  <!-- 状态卡片 -->
  <view class="status-card status-{{order.statusCode}}">
    <view class="status-icon">{{statusIcon}}</view>
    <view class="status-text">{{order.statusText}}</view>
    <view class="status-desc" wx:if="{{order.statusCode === 1}}">
      请在 {{checkinDeadline}} 前完成签到
    </view>
    <view class="status-desc" wx:elif="{{order.statusCode === 4}}">
      因超时未签到，已记录违约
    </view>
  </view>

  <!-- 座位信息卡片 -->
  <view class="card">
    <view class="card-title">
      <text class="title-icon">🪑</text>
      <text>座位信息</text>
    </view>
    <view class="info-row">
      <text class="label">座位号</text>
      <text class="value highlight">{{order.seat}}号</text>
    </view>
    <view class="info-row">
      <text class="label">自习室</text>
      <text class="value">{{order.roomName || 'A区自习室'}}</text>
    </view>
  </view>

  <!-- 时间信息卡片 -->
  <view class="card">
    <view class="card-title">
      <text class="title-icon">📅</text>
      <text>时间信息</text>
    </view>
    <view class="info-row">
      <text class="label">预约日期</text>
      <text class="value">{{order.date}}</text>
    </view>
    <view class="info-row">
      <text class="label">预约时段</text>
      <text class="value">{{order.time}}</text>
    </view>
    <view class="info-row">
      <text class="label">签到时间</text>
      <text class="value">{{order.checkinTime || '未签到'}}</text>
    </view>
    <view class="info-row" wx:if="{{order.cancelTime}}">
      <text class="label">取消时间</text>
      <text class="value">{{order.cancelTime}}</text>
    </view>
  </view>

  <!-- 预约单号 -->
  <view class="card">
    <view class="card-title">
      <text class="title-icon">📋</text>
      <text>订单信息</text>
    </view>
    <view class="info-row">
      <text class="label">预约单号</text>
      <text class="value mono">{{order.orderNo || order.createTime}}</text>
    </view>
    <view class="info-row">
      <text class="label">创建时间</text>
      <text class="value">{{order.createTimeText || '--'}}</text>
    </view>
  </view>

  <!-- 操作按钮（仅待签到状态显示） -->
  <view class="action-buttons" wx:if="{{order.statusCode === 1}}">
    <button class="btn-outline" bindtap="cancelOrder">取消预约</button>
    <button class="btn-primary" bindtap="goCheckin">去签到</button>
  </view>

  <!-- 已签到状态提示 -->
  <view class="tips-card" wx:elif="{{order.statusCode === 2}}">
    <text class="tips-icon">✅</text>
    <text class="tips-text">你已完成签到，请按时到场使用座位</text>
  </view>

  <!-- 违约状态提示 -->
  <view class="tips-card warning" wx:elif="{{order.statusCode === 4}}">
    <text class="tips-icon">⚠️</text>
    <text class="tips-text">违约记录会影响后续预约权限，请遵守规则</text>
  </view>

  <!-- 系统规则 -->
  <view class="rules-card">
    <view class="rules-title">📌 预约规则</view>
    <view class="rules-list">
      <text>• 预约后15分钟内需完成签到</text>
      <text>• 超时未签到自动取消并记录违约</text>
      <text>• 可提前30分钟主动取消预约</text>
      <text>• 累计违约3次，限制预约7天</text>
    </view>
  </view>
</view>