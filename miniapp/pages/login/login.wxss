.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
}

.logo-area {
  text-align: center;
  margin-bottom: 80rpx;
}

.app-name {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.slogan {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.login-area {
  width: 100%;
  padding: 0 60rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #1677ff;
  color: white;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.footer {
  position: absolute;
  bottom: 50rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.footer text {
  font-size: 24rpx;
  color: #bbb;
}